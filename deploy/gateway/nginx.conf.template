# Credential-injecting gateway (ADR-0010). The ${...} keys are substituted at container start
# from mounted secret files (entrypoint.sh); they live ONLY in this gateway, never in a worker.
#
# A worker points ANTHROPIC_BASE_URL / OPENAI_BASE_URL at this gateway with a PLACEHOLDER key.
# nginx terminates the worker's plain-HTTP request on the sealed network, overrides the auth header
# with the real provider key, and forwards to the real provider over verified TLS, streaming the
# response back. The upstream is hardwired per port, so a worker cannot redirect it elsewhere.
worker_processes 1;
events { worker_connections 256; }

http {
    access_log off;  # request bodies carry prompts — do not log them

    # --- Anthropic (Claude) : workers set ANTHROPIC_BASE_URL=http://<gateway>:8800 ---
    server {
        listen 8800;
        location / {
            proxy_pass https://api.anthropic.com;
            proxy_set_header Host api.anthropic.com;
            proxy_set_header x-api-key "${ANTHROPIC_API_KEY}";   # replaces the worker's placeholder
            proxy_ssl_server_name on;
            proxy_ssl_name api.anthropic.com;
            proxy_ssl_verify on;
            proxy_ssl_trusted_certificate /etc/ssl/certs/ca-certificates.crt;
            proxy_http_version 1.1;
            proxy_buffering off;       # stream SSE responses straight through
            proxy_read_timeout 600s;
        }
    }

    # --- OpenAI (Codex) : workers set OPENAI_BASE_URL=http://<gateway>:8801 ---
    server {
        listen 8801;
        location / {
            proxy_pass https://api.openai.com;
            proxy_set_header Host api.openai.com;
            proxy_set_header Authorization "Bearer ${OPENAI_API_KEY}";  # replaces the placeholder
            proxy_ssl_server_name on;
            proxy_ssl_name api.openai.com;
            proxy_ssl_verify on;
            proxy_ssl_trusted_certificate /etc/ssl/certs/ca-certificates.crt;
            proxy_http_version 1.1;
            proxy_buffering off;
            proxy_read_timeout 600s;
        }
    }
}
