# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
.env

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
uv.lock

# Secrets — NEVER commit. The system reads secrets from files at runtime; those
# files live outside the repo (e.g. ~/talisman/secrets/) and must never be staged.
secrets/
*.secret
*.key
*.pem

# SQLite runtime state (the deployed system stores state under ~/talisman/)
*.sqlite3
*.sqlite3-wal
*.sqlite3-shm

# OS
.DS_Store

# Claude Code session artifacts (cron / scheduled tasks)
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json
